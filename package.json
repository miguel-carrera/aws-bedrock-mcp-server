{
  "name": "@miguel-carrera/aws-bedrock-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for AWS Bedrock Knowledge Base — semantic search and RAG via bedrock_retrieve and bedrock_retrieve_and_generate",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aws-bedrock-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "aws",
    "bedrock",
    "knowledge-base",
    "rag",
    "claude"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/miguel-carrera/aws-bedrock-mcp-server.git"
  },
  "homepage": "https://github.com/miguel-carrera/aws-bedrock-mcp-server#readme",
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.758.0",
    "@aws-sdk/client-cognito-identity": "^3.1065.0",
    "@aws-sdk/credential-provider-cognito-identity": "^3.972.44",
    "@aws-sdk/credential-providers": "^3.758.0",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "open": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
